// Zellij config — minimal defaults
// Docs: https://zellij.dev/documentation/configuration

keybinds clear-defaults=false {
}

theme "default"

// Use system clipboard
copy_on_select true

// Simplified UI
simplified_ui false
pane_frames true
default_layout "default"

// Mouse support
mouse_mode true

// Scrollback
scroll_buffer_size 50000

// Session
session_serialization true
